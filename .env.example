# ============================================================================
# Entangle — environment configuration
# Copy to .env (root, for engine + infra) and apps/web/.env.local (for the web app).
# Never commit real values. The web app only needs server-side access; none of
# these are exposed with NEXT_PUBLIC_ prefixes.
# ============================================================================

# --- AWS credentials & region -----------------------------------------------
# Locally, you can instead rely on an AWS profile / SSO and omit the keys.
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Optional: use a named profile instead of inline keys.
# AWS_PROFILE=default

# --- DynamoDB (live entangled-pair inventory) -------------------------------
DYNAMODB_TABLE=EntangledPairs

# --- Aurora PostgreSQL Serverless v2 (RDS Data API) -------------------------
# The cluster ARN of the Aurora Serverless v2 cluster (Data API enabled).
AURORA_CLUSTER_ARN=arn:aws:rds:us-east-1:000000000000:cluster:entangle
# The Secrets Manager ARN holding the DB master credentials.
AURORA_SECRET_ARN=arn:aws:secretsmanager:us-east-1:000000000000:secret:entangle-db
# The logical database name inside the cluster.
AURORA_DATABASE=entangle

# --- Simulation engine tuning (defaults; also runtime-tunable via /api/control)
ENGINE_TICKS_PER_SEC=10
ENGINE_GEN_MULTIPLIER=1.0
ENGINE_DECOHERENCE_MULTIPLIER=1.0
ENGINE_FIDELITY_FLOOR=0.5
