{
  "name": "entangle",
  "version": "0.1.0",
  "private": true,
  "description": "Entangle — a control plane for a simulated quantum network (H0 hackathon).",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "dev:engine": "pnpm --filter @entangle/engine dev",
    "dev:web": "pnpm --filter @entangle/web dev",
    "infra:migrate": "pnpm --filter @entangle/infra migrate",
    "infra:seed": "pnpm --filter @entangle/infra seed"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "tsx": "^4.19.2",
    "@types/node": "^20.17.6"
  }
}
